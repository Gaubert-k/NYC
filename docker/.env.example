# Configuration unique — copier vers docker/.env
#   cp docker/.env.example docker/.env
COMPOSE_PROJECT_NAME=nyc-lakehouse

# ─── HDFS ───────────────────────────────────────────────────
HDFS_URI=hdfs://namenode:9000

# ─── Spark cluster ────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=3G
SPARK_WORKER_CORES=4
SPARK_NUM_EXECUTORS=2
SPARK_EXECUTOR_CORES=2
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=2g
SPARK_SHUFFLE_PARTITIONS=16
SPARK_EVENT_LOG_DIR=file:/spark-events

# ─── Limites memoire conteneurs ───────────────────────────────
SPARK_MASTER_MEM_LIMIT=1g
SPARK_WORKER_MEM_LIMIT=3g
SPARK_CLIENT_MEM_LIMIT=2g
SPARK_HISTORY_MEM_LIMIT=512m
NAMENODE_MEM_LIMIT=1g
DATANODE_MEM_LIMIT=2g
MONGODB_MEM_LIMIT=512m
PROMETHEUS_MEM_LIMIT=512m
GRAFANA_MEM_LIMIT=512m

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DATABASE=nyc_taxi_warehouse

# ─── Grafana ─────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ─── Pipeline (injecte dans spark-client par scripts/docker/pipeline.sh) ─
DOCKER_MODE=true
STORAGE_BACKEND=hdfs
GOLD_PARQUET_FALLBACK=true
LIGHT_MODE=false
