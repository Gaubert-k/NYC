# Variables Docker — copier vers docker/.env ou utiliser --env-file
COMPOSE_PROJECT_NAME=nyc-lakehouse

# HDFS
HDFS_NAMENODE_HOST=namenode
HDFS_PORT=9000

# Spark
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2
SPARK_WORKER_REPLICAS=2

# MongoDB
MONGO_DATABASE=nyc_taxi_warehouse

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Limites memoire par service (ajuster selon RAM dispo)
NAMENODE_MEM_LIMIT=1g
DATANODE_MEM_LIMIT=1g
SPARK_MASTER_MEM_LIMIT=1g
SPARK_WORKER_MEM_LIMIT=2g
MONGODB_MEM_LIMIT=512m
PROMETHEUS_MEM_LIMIT=512m
GRAFANA_MEM_LIMIT=512m
