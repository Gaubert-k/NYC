# Copier vers .env à la racine du projet
PROJECT_ROOT=.

# Mode développement : limite les fichiers traités
SAMPLE_MODE=true
MAX_MONTHS_PER_TYPE=2

# Spark
SPARK_MODE=local
SPARK_NUM_EXECUTORS=2
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# MongoDB (local ou Docker)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=nyc_taxi_warehouse

# Gold : écrire aussi en Parquet si Mongo indisponible
GOLD_PARQUET_FALLBACK=true

# Mode ultra-léger (~1 Go RAM)
LIGHT_MODE=false

# Monitoring
METRICS_LOG_PATH=logs/pipeline_metrics.jsonl
PROMETHEUS_EXPORT_PATH=logs/pipeline_metrics.prom
